---
// src/components/Hero.astro
---
<section id="hero" aria-label="Hero – Introduction">
  <div class="hero-inner">

    <!-- Left: Content -->
    <div class="hero-content">
      <div class="hero-badge">Senior Marketing Manager · Full Stack Marketer</div>

      <h1>Valerie<br />Singleton</h1>

      <p class="hero-tagline">GROWTH MARKETING MANAGER | CAMPAIGN EXECUTION | ANALYTICS SPECIALIST | WEB SPECIALIST</p>

      <ul class="hero-contact-row" aria-label="Contact details">
        <!-- Phone -->
        <li class="hero-contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
               stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07
                     A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67
                     A2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81
                     a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l.77-.77
                     a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7
                     A2 2 0 0 1 22 16.92z"/>
          </svg>
          <a href="tel:+12404626019" style="color:rgba(255,255,255,0.65); text-decoration:none;">240.462.6019</a>
        </li>
        <!-- Email -->
        <li class="hero-contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
               stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          <a href="mailto:valerie.singleton07@gmail.com"
             style="color:rgba(255,255,255,0.65); text-decoration:none;">
            valerie.singleton07@gmail.com
          </a>
        </li>
        <!-- Location -->
        <li class="hero-contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
               stroke-linejoin="round" aria-hidden="true">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span>Washington, DC</span>
        </li>
      </ul>

      <div class="hero-actions">
        <a href="#case-studies" class="btn btn-primary">
          View Case Studies
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
               stroke-linejoin="round" aria-hidden="true">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </a>
        <a href="#contact" class="btn btn-white">Get In Touch</a>
      </div>
    </div>

    <!-- Right: Visual / Avatar -->
    <div class="hero-visual">
      <div class="hero-avatar" aria-label="Professional headshot">
        <img 
          src="/images/vsingleton_headshot.PNG" 
          alt="Valerie Singleton - Professional Headshot"
          class="hero-avatar-img"
        />
      </div>
    </div>
  </div>

  <!-- Scroll down indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <span>Scroll</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
         stroke-linejoin="round">
      <path d="m6 9 6 6 6-6"/>
    </svg>
  </div>
</section>
