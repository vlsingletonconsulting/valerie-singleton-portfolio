    number: '04',
    title:  'Multi-Client Enrollment Campaign Management',
    client: 'Blackboard',
    role:   'Marketing & Analytics Lead',
    badge:  '18% Enrollment Growth',
    slug: 'blackboard-enrollment-campaigns',
