---
// src/components/Contact.astro
---
<section id="contact" class="section" aria-labelledby="contact-heading">
  <div class="container">

    <h2 class="section-title" id="contact-heading">Let's Connect</h2>
    <p class="section-subtitle">
      Ready to drive measurable growth? Let's talk about how I can bring
      strategic marketing leadership to your team.
    </p>

    <div class="contact-grid">

      <!-- Left: Contact Info -->
      <div class="contact-info fade-in">
        <h3>Get In Touch</h3>
        <p>
          Whether you're looking for a senior marketing leader, want to discuss
          a specific challenge, or simply want to connect—I'd love to hear from you.
        </p>

        <ul class="contact-details" role="list" aria-label="Contact information">
          <!-- Email -->
          <li>
            <span class="contact-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                   stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </span>
            <div>
              <div style="font-size:0.78rem; color:#999; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:2px;">Email</div>
              <a href="mailto:valerie.singleton07@gmail.com">valerie.singleton07@gmail.com</a>
            </div>
          </li>
          <!-- Phone -->
          <li>
            <span class="contact-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                   stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l.77-.77a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </span>
            <div>
              <div style="font-size:0.78rem; color:#999; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:2px;">Phone</div>
              <a href="tel:+12404626019">240.462.6019</a>
            </div>
          </li>
          <!-- Location -->
          <li>
            <span class="contact-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                   stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </span>
            <div>
              <div style="font-size:0.78rem; color:#999; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:2px;">Location</div>
              <span style="color:var(--color-text);">Washington, DC</span>
            </div>
          </li>
          <!-- LinkedIn -->
          <li>
            <span class="contact-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                   fill="currentColor">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
            </span>
            <div>
              <div style="font-size:0.78rem; color:#999; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:2px;">LinkedIn</div>
              <a href="https://www.linkedin.com/in/valerie-singleton-8174796/" target="_blank" rel="noopener noreferrer">https://www.linkedin.com/in/valerie-singleton-8174796/</a>
            </div>
          </li>
        </ul>

        <!-- Availability note -->
        <div style="
          background: rgba(39,174,96,0.08);
          border: 1px solid rgba(39,174,96,0.25);
          border-radius: 8px;
          padding: 14px 16px;
          margin-bottom: 24px;
          display: flex;
          align-items: center;
          gap: 10px;
          font-size: 0.88rem;
          color: #1e7e46;
          font-weight: 600;
        ">
          <span style="width:10px; height:10px; border-radius:50%; background:#27ae60; flex-shrink:0; animation: pulse 2s infinite;" aria-hidden="true"></span>
          Available for new opportunities
        </div>

        <!-- Social Icons -->
        <div class="contact-social" aria-label="Social media links">
          <a href="https://www.linkedin.com/in/valerie-singleton-8174796/" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="Connect on LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                 fill="currentColor">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <a href="mailto:valerie.singleton07@gmail.com" class="social-btn" aria-label="Send email">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                 stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div class="contact-form-wrap fade-in">
        <h3>Send a Message</h3>

        <!-- Success / Error messages -->
        <div id="form-success" class="form-success" role="alert" aria-live="polite">
          ✓ Message sent! I'll be in touch within 24 hours.
        </div>
        <div id="form-error" class="form-error" role="alert" aria-live="polite">
          ✕ Something went wrong. Please email me directly at valerie.singleton07@gmail.com
        </div>

        <!-- Netlify form (data-netlify="true") -->
        <form
          id="contact-form"
          name="portfolio submit"
          method="POST"
          action="/"
          data-netlify="true"
          netlify-honeypot="bot-field"
          novalidate
        >
          <!-- Netlify hidden fields -->
          <input type="hidden" name="form-name" value="portfolio submit" />

          <!-- Honeypot anti-spam -->
          <div class="ohnohoney" aria-hidden="true">
            <label for="bot-field">Don't fill this out if you're human:</label>
            <input id="bot-field" name="bot-field" tabindex="-1" autocomplete="off" />
          </div>

          <!-- Name + Email row -->
          <div class="form-row">
            <div class="form-group">
              <label for="contact-name">Full Name <span aria-hidden="true" style="color:var(--color-error);">*</span></label>
              <input
                type="text"
                id="contact-name"
                name="name"
                placeholder="Jane Smith"
                required
                aria-required="true"
                autocomplete="name"
              />
            </div>
            <div class="form-group">
              <label for="contact-email">Email Address <span aria-hidden="true" style="color:var(--color-error);">*</span></label>
              <input
                type="email"
                id="contact-email"
                name="email"
                placeholder="jane@company.com"
                required
                aria-required="true"
                autocomplete="email"
              />
            </div>
          </div>

          <!-- Subject -->
          <div class="form-group">
            <label for="contact-subject">Subject</label>
            <input
              type="text"
              id="contact-subject"
              name="subject"
              placeholder="Marketing Leadership Opportunity / Consulting Inquiry"
              autocomplete="off"
            />
          </div>

          <!-- Message -->
          <div class="form-group">
            <label for="contact-message">Message <span aria-hidden="true" style="color:var(--color-error);">*</span></label>
            <textarea
              id="contact-message"
              name="message"
              placeholder="Tell me about your project or opportunity..."
              required
              aria-required="true"
            ></textarea>
          </div>

          <!-- Submit -->
          <button type="submit" class="form-submit" aria-label="Send message">
            Send Message →
          </button>
          <p class="form-note">
            Or email directly:
            <a href="mailto:valerie.singleton07@gmail.com">valerie.singleton07@gmail.com</a>
          </p>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(39,174,96,0.4); }
    50%       { box-shadow: 0 0 0 6px rgba(39,174,96,0); }
  }
</style>
