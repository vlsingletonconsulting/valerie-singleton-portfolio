---
// src/pages/projects/[slug].astro
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';

export async function getStaticPaths() {
  const projects = [
    {
      slug: 'salesforce-hubspot-migration',
      title: 'Salesforce → HubSpot Migration',
      category: 'MarTech & Automation',
      image: '/images/Genspark-Meridian-Financial-Salesforce-to-HubSpot-Migration-Report-02-28-2026_12_26_AM.png',
      description: 'Marketing platform migration from Salesforce Marketing Cloud to HubSpot with zero downtime, eliminating developer dependency and significantly reducing costs.',
      fullDescription: 'Salesforce Marketing Cloud was prohibitively expensive with high platform fees plus ongoing specialized developer costs. Led complete migration to HubSpot while maintaining Salesforce CRM integration without disrupting live campaigns using an "Audit-Rebuild-Validate" framework.',
      technologies: ['HubSpot', 'Salesforce', 'Marketing Automation', 'CRM Integration', 'MarTech'],
      client: 'MainStreet Bank',
      role: 'Project Lead',
      duration: '4 months',
      results: [
        { metric: 'Downtime', value: 'Zero', description: 'All live campaigns maintained throughout migration' },
        { metric: 'Migration Success', value: '100%', description: 'Complete platform transition achieved' },
        { metric: 'Cost Reduction', value: 'Significant', description: 'Eliminated licensing + developer retainer fees' },
        { metric: 'Team Independence', value: 'Achieved', description: 'Team now builds and launches without dev support' }
      ]
    },
    {
      slug: 'executive-analytics-dashboard',
      title: 'Performance Marketing',
      category: 'Analytics & Reporting',
      image: '/images/Analytics-Dashboard-—-Traffic-Growth-02-28-2026_12_56_AM.png',
      description: 'Comprehensive analytics dashboard providing real-time visibility across marketing channels, enabling data-driven decisions and executive alignment on performance metrics.',
      fullDescription: 'This executive analytics dashboard was designed to provide C-suite leadership with a comprehensive view of marketing performance across all channels. The solution integrates data from Google Analytics, CRM systems, and advertising platforms to create a unified reporting experience.',
      technologies: ['GA4', 'Data Visualization', 'Executive Reporting', 'Dashboard Development'],
      client: 'Financial Services Client',
      role: 'Analytics & Reporting Lead',
      duration: '3 months',
      results: [
        'Reduced reporting time by 75% through automated dashboard',
        'Improved executive decision-making with real-time insights',
        'Unified 12+ data sources into single view',
        'Increased marketing ROI visibility across channels'
      ]
    },
    {
      slug: 'keyword-rank-tracking-system',
      title: 'Keyword Rank Tracking System',
      category: 'Technical SEO',
      image: '/images/Keyword-Rank-Tracker-Light-Mode-02-28-2026_01_50_AM.png',
      description: 'Advanced SEO tracking system monitoring keyword performance across search engines, providing actionable insights for organic visibility optimization.',
      fullDescription: 'Developed a comprehensive keyword rank tracking system that monitors organic search performance across multiple search engines and geographic locations. The system provides daily updates, competitive analysis, and actionable insights for SEO strategy optimization.',
      technologies: ['SEO', 'Rank Tracking', 'Performance Monitoring', 'Data Analysis'],
      client: 'B2B Technology Company',
      role: 'Technical SEO Lead',
      duration: '4 months',
      results: [
        'Achieved 45% average ranking improvement for target keywords',
        'Increased organic traffic by 50% year-over-year',
        'Identified and captured 200+ new keyword opportunities',
        'Improved SERP visibility for core business terms'
      ]
    },
    {
      slug: 'cro-campaign-testing',
      title: 'CRO Campaign Testing Results',
      category: 'Conversion Optimization',
      image: '/images/CRO-Campaign-1-Pager-—-Form-Headline-A-B-Test-02-28-2026_02_08_AM.png',
      description: 'Systematic A/B testing program optimizing form headlines and conversion elements, driving measurable improvements in lead generation and user engagement.',
      fullDescription: 'Implemented a comprehensive conversion rate optimization program focused on form performance and user experience improvements. Through systematic A/B testing of headlines, layouts, and conversion elements, we significantly improved lead generation effectiveness.',
      technologies: ['A/B Testing', 'CRO', 'Conversion Rate', 'User Experience'],
      client: 'Education Institution',
      role: 'Conversion Optimization Specialist',
      duration: '6 months',
      results: [
        'Increased form completion rates by 35%',
        'Improved lead quality through optimized messaging',
        'Reduced form abandonment by 28%',
        'Generated 18% increase in qualified leads'
      ]
    },
    {
      slug: 'abm-campaign-creative',
      title: 'ABM Campaign Creative Suite',
      category: 'Account-Based Marketing',
      image: '/images/Your-Private-GovCon-Banker-on-Speed-Dial-02-27-2026_11_55_PM.png',
      description: 'Targeted account-based marketing campaign with personalized creative assets and direct mail components driving engagement with high-value prospects.',
      fullDescription: 'Developed a comprehensive ABM campaign strategy for high-value government contracting prospects. The campaign integrated personalized digital experiences with direct mail components to create a multi-touch engagement strategy.',
      technologies: ['ABM', 'Direct Mail', 'Personalization', 'Account-Based Strategy'],
      client: 'Government Contracting Firm',
      role: 'ABM Strategy Lead',
      duration: '5 months',
      results: [
        'Generated 150+ qualified meetings with target accounts',
        'Achieved 25% engagement rate from personalized outreach',
        'Expanded pipeline by $2.5M in target accounts',
        'Established scalable ABM framework for future campaigns'
      ]
    },
    {
      slug: 'pipeline-performance-dashboard',
      title: 'Pipeline Performance Dashboard',
      category: 'Marketing Operations',
      image: '/images/Pipeline_Metrics_Report.png',
      description: 'Comprehensive pipeline tracking system monitoring marketing and sales alignment, providing insights into conversion rates and revenue generation.',
      fullDescription: 'Built a comprehensive pipeline performance dashboard that bridges marketing and sales data to provide complete visibility into revenue generation. The system tracks leads from initial touchpoint through closed deals, enabling better alignment and forecasting.',
      technologies: ['Pipeline', 'Sales Alignment', 'Revenue Tracking', 'CRM Integration'],
      client: 'Financial Services Organization',
      role: 'Marketing Operations Lead',
      duration: '4 months',
      results: [
        'Improved sales-marketing alignment by 40%',
        'Reduced lead response time by 60%',
        'Increased pipeline visibility for forecasting',
        'Generated 22% improvement in conversion rates'
      ]
    },
    {
      slug: 'crm-migration-validation',
      title: 'CRM Migration Validation',
      category: 'Marketing Technology',
      image: '/images/Genspark-Meridian-Financial-Salesforce-to-HubSpot-Migration-Report-02-28-2026_12_26_AM.png',
      description: 'End-to-end Salesforce to HubSpot migration with comprehensive validation reporting, ensuring zero data loss and improved operational efficiency.',
      fullDescription: 'Led a complete CRM migration from Salesforce Marketing Cloud to HubSpot Marketing Hub, including data migration, workflow recreation, and comprehensive validation. The project involved complex data mapping, automation rebuild, and stakeholder training.',
      technologies: ['Migration', 'HubSpot', 'Salesforce', 'Data Validation'],
      client: 'Financial Services Company',
      role: 'Project Lead',
      duration: '6 months',
      results: [
        { metric: 'Data Accuracy', value: '100%', description: 'Zero data loss during migration' },
        { metric: 'Workflow Efficiency', value: '+40%', description: 'Improved automation performance' },
        { metric: 'User Adoption', value: '95%', description: 'Team trained and using new system' }
      ]
    },
    {
      slug: 'merchant-services-campaign',
      title: 'Merchant Services Growth Campaign',
      category: 'B2B Marketing',
      image: '/images/1_merchant_services.png',
      description: 'Competing Against Stripe & Square with a Relationship-First Strategy',
      fullDescription: 'Took on Stripe and Square with a community bank product that had eligibility restrictions and a skeptical sales team standing between it and customers. Built a campaign that turned business bankers into advocates first, then drove qualified acquisition through trust-led messaging the big players couldn\'t replicate.',
      technologies: ['B2B Marketing', 'Demand Gen', 'Internal Enablement', 'Financial Services'],
      client: 'MainStreet Bank',
      role: 'Campaign Strategy & Execution Lead',
      duration: '3 months',
      results: [
        { metric: 'Banker Engagement', value: 'Increased', description: 'Product engagement following enablement rollout' },
        { metric: 'Qualified Pipeline', value: 'Generated', description: 'Pre-qualified business customers' },
        { metric: 'Campaign Framework', value: 'Established', description: 'Repeatable acquisition campaign framework' }
      ]
    },
    {
      slug: 'govcon-abm-campaign',
      title: 'GovCon ABM Campaign',
      category: 'Account-Based Marketing',
      image: '/images/govcon_abm_campaign.png',
      description: 'Re-establishing Market Presence After Relationship Shifts using Account Based Marketing',
      fullDescription: 'Broke into the government contracting market with a precision ABM strategy targeting DC-area GovCon business owners across LinkedIn, exclusive in-person events, and a dedicated content hub. The pilot generated qualified pipeline and became the blueprint for a multi-vertical ABM program.',
      technologies: ['Account-Based Marketing', 'Event Marketing', 'Content Hub', 'LinkedIn', 'B2B'],
      client: 'MainStreet Bank',
      role: 'ABM Strategy & Multi-Channel Execution Lead',
      duration: '4 months',
      challenge: 'MainStreet Bank needed to break into the highly competitive government contracting market, where established relationships and industry expertise were significant barriers to entry for new financial services providers.',
      strategy: 'Developed a precision ABM strategy targeting DC-area GovCon business owners through LinkedIn outreach, exclusive industry events, and a dedicated content hub focused on government contracting financial challenges.',
      execution: [
        'Launched targeted LinkedIn campaigns reaching C-level executives in government contracting',
        'Hosted exclusive GovCon networking events at DC-area venues for qualified prospects',
        'Created dedicated content hub with government contracting financial insights and resources',
        'Implemented multi-touch engagement strategy combining digital and in-person interactions',
        'Developed relationship-first messaging emphasizing financial expertise in GovCon space'
      ],
      results: [
        'Successfully launched first ABM pilot targeting GovCon vertical',
        'Generated inbound engagement from qualified government contracting business owners',
        'Created high-value account pipeline from exclusive industry events',
        'Developed scalable ABM framework adapted across additional business verticals',
        'Established MainStreet Bank as credible financial services provider in GovCon market'
      ],
      images: [
        { label: 'GovCon Social Media Campaign', desc: 'LinkedIn and social media content targeting government contractors' },
        { label: 'GovCon Event Advertising', desc: 'Event marketing materials for exclusive GovCon networking events' }
      ]
    },
    {
      slug: 'venu-cannabis-app',
      title: 'Venu — Cannabis Payment App',
      category: 'Fintech',
      image: '/images/venu_cannabis_app.png',
      description: 'Marketing Where Traditional Ads Can\'t Go',
      fullDescription: 'Launched brand awareness for a cannabis fintech product in one of the most ad-restricted industries in marketing. Used compliant educational content and targeted outreach to build credibility and generate a verified pipeline of medical dispensaries in Michigan and Illinois.',
      technologies: ['Fintech', 'Cannabis Industry', 'Regulated Market Marketing', 'Brand Awareness'],
      client: 'MainStreet Bank',
      role: 'Regulated Market Campaign Lead',
      duration: '6 months',
      results: [
        { metric: 'Brand Awareness', value: 'Built', description: 'Target expansion markets despite channel restrictions' },
        { metric: 'Content Engagement', value: 'Drove', description: 'Measurable engagement from dispensary operators' },
        { metric: 'Verified Pipeline', value: 'Generated', description: 'Medical dispensary prospects in Michigan & Illinois' }
      ]
    },
    {
      slug: 'blackboard-enrollment-campaigns',
      title: 'Enrollment Campaigns',
      category: 'EdTech',
      image: '/images/blackboard_campaigns.png',
      description: '11 Clients. 18% More Students Enrolled.',
      fullDescription: 'Managing 100+ quarterly campaigns for 11+ higher education institutions simultaneously — zero margin for error, every deadline met. Drove an 18% aggregate enrollment increase through data-driven management, 30+ A/B tests, and real-time optimization.',
      technologies: ['EdTech', 'Multi-Client Management', 'CRO', 'A/B Testing', 'SEO & Analytics'],
      client: 'Blackboard',
      role: 'Campaign Manager & Analytics Lead',
      duration: '6 years (2014–2020)',
      results: [
        { metric: 'Enrollment Increase', value: '18%', description: 'Aggregate increase across client base' },
        { metric: 'A/B Tests', value: '30+', description: '7% bounce rate reduction, 15,000 qualified leads' },
        { metric: 'Microsites', value: '27', description: 'Delivered on time and within budget' },
        { metric: 'On-Time Delivery', value: '100%', description: 'Perfect delivery record' },
        { metric: 'Customer Retention', value: '+10%', description: 'Increased customer retention' }
      ]
    },
    {
      slug: 'vsingleton-consulting',
      title: 'Performance Marketing',
      category: 'Analytics & Consulting',
      image: '/images/vsingleton_consulting.png',
      description: 'From Data Gaps to Decision Clarity',
      fullDescription: 'Delivered end-to-end digital marketing solutions across analytics, web, and paid media. From fixing broken GA4 implementations to building executive Looker Studio dashboards to running LinkedIn B2B campaigns — every engagement started with an honest audit and ended with clients who could act on their data.',
      technologies: ['GA4 Audit', 'Google Tag Manager', 'Looker Studio'],
      client: 'Multiple Clients',
      role: 'Analytics, Web & Paid Media Consultant',
      duration: '6 years (2019–Present)',
      results: [
        { metric: 'Tracking Gaps', value: 'Resolved', description: 'Critical tracking gaps causing misattribution' },
        { metric: 'Manual Reporting', value: 'Eliminated', description: 'Dashboards saving hours per week' },
        { metric: 'LinkedIn Pipeline', value: 'Generated', description: 'Qualified B2B leads with measurable impact' },
        { metric: 'Website Performance', value: 'Improved', description: 'Organic visibility and conversion rates' }
      ]
    },
    {
      slug: 'business-banking-sem',
      title: 'SEM & PPC',
      category: 'Paid Search',
      image: '/images/business_banking_sem.png',
      description: 'Competing Smart, Not Loud, in a High-Cost Category',
      fullDescription: 'Managed Google Ads campaigns for a community bank\'s business banking products competing against national brands with vastly bigger budgets. Focused spend on high-intent local and niche queries that drove qualified leads at an efficient cost-per-acquisition.',
      technologies: ['SEM', 'PPC', 'Google Ads', 'Paid Search', 'Financial Services'],
      client: 'MainStreet Bank',
      role: 'Paid Search Lead',
      duration: 'Ongoing',
      results: [
        { metric: 'Cost-Per-Acquisition', value: 'Efficient', description: 'Maintained efficiency despite high-CPM category' },
        { metric: 'Lead Quality', value: 'Improved', description: 'Continuous optimization reduced wasted spend' },
        { metric: 'Conversion Tracking', value: 'Full', description: 'Visibility into campaigns driving account openings' }
      ]
    },
    {
      slug: 'enterprise-abm-program',
      title: 'Enterprise ABM Program',
      category: 'Account-Based Marketing',
      image: '/images/Venu ABM.png',
      description: 'Pipeline Through Strategic Account-Based Marketing',
      fullDescription: 'Developed and executed a comprehensive enterprise ABM program targeting high-value accounts across multiple industries. The program integrated personalized content, multi-channel outreach, and data-driven account selection to generate significant pipeline revenue.',
      technologies: ['Account-Based Marketing', 'LinkedIn Sales Navigator', 'Personalization', 'Sales Enablement', 'Enterprise Strategy'],
      client: 'Enterprise Technology Client',
      role: 'ABM Strategy & Execution Lead',
      duration: '6 months',
      results: [
        'Generated multi-million dollar pipeline from target accounts',
        'Achieved 300% ROI on ABM program investment',
        'Increased engagement rates by 45% with personalized content',
        'Established scalable ABM framework for enterprise clients'
      ]
    }
  ];

  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} - Project Details | Valerie Singleton`} description={project.description}>
  <Navigation />
  <main id="main-content">
    <section class="project-detail-section">
      <div class="project-detail-container">
        
        <!-- Hero Visual Section -->
        <section class="hero-visual-section">
          <div class="hero-visual-container">
            <div class="case-study-hero">
              <div class="hero-gradient"></div>
              <div class="hero-pattern"></div>
              <div class="hero-content">
                <div class="project-badge">Case Study</div>
                <h1 class="hero-title">{project.title}</h1>
                <p class="hero-subtitle">{project.description}</p>
                <div class="hero-meta">
                  <span class="hero-category">{project.category}</span>
                  <span class="hero-client">Executive Reporting</span>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Technologies Section -->
        <section class="technologies-section">
          <h2 class="section-title" style="border-bottom: none;">Technologies</h2>
          <div class="tech-grid">
            {project.technologies.map(tech => (
              <div class="tech-card">
                <div class="tech-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 15.09 8.26 22 9 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9 8.91 8.26 12 2"></polygon>
                  </svg>
                </div>
                <span class="tech-name">{tech}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Gallery Modal -->
        <div id="galleryModal" class="gallery-modal" onclick="closeGalleryModal()">
          <button class="gallery-modal-close" onclick="closeGalleryModal()">&times;</button>
          <img id="galleryModalImage" class="gallery-modal-content" src="" alt="Enlarged view" onclick="toggleGalleryZoom(event)">
          <div class="gallery-zoom-hint">Click image to zoom</div>
          <div class="gallery-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3182ce" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
              <line x1="11" y1="8" x2="11" y2="14"></line>
              <line x1="8" y1="11" x2="14" y2="11"></line>
            </svg>
          </div>
        </div>

        <!-- Case Study Details -->
        {project.slug === 'merchant-services-campaign' ? (
          <div class="case-study-section">
            <h2 class="section-title">Project Details</h2>
            
            <div class="case-study-content">
              <div class="case-study-block">
                <h3 class="case-study-label">The Challenge</h3>
                <p class="case-study-text">
                  MainStreet Bank's merchant services division was competing against Stripe and Square with vastly bigger budgets. Traditional bank marketing wasn't working — business owners weren't switching payment processors for better rates alone. They needed to see the value of a banking relationship, not just a transaction.
                </p>
              </div>

              <div class="case-study-block">
                <h3 class="case-study-label">Strategy</h3>
                <p class="case-study-text">
                  Relationship-first banking. Instead of competing on price, we positioned MainStreet as the partner who understands business banking needs. Created campaigns that spoke to business owners' real challenges — cash flow management, growth planning, and having a banker who actually answers the phone.
                </p>
              </div>

              <div class="case-study-block">
                <h3 class="case-study-label">Execution</h3>
                <ul class="case-study-list">
                  <li>Developed comprehensive digital advertising campaigns across Google Ads and LinkedIn</li>
                  <li>Created relationship-focused messaging emphasizing banking partnership over transaction</li>
                  <li>Built landing pages and conversion funnels optimized for business banking leads</li>
                  <li>Implemented tracking and analytics to measure campaign effectiveness and ROI</li>
                  <li>Managed ongoing campaign optimization and budget allocation</li>
                </ul>
              </div>

              <div class="case-study-block">
                <h3 class="case-study-label">Results</h3>
                <ul class="case-study-results">
                  <li>Generated qualified business banking leads at efficient cost-per-acquisition</li>
                  <li>Achieved strong ROI on digital advertising investment</li>
                  <li>Established MainStreet as competitive alternative to national processors</li>
                  <li>Built sustainable pipeline for merchant services division</li>
                </ul>
              </div>

              <div class="case-study-block">
                <h3 class="case-study-label">Project Screenshots</h3>
                <div class="project-screenshots" style="display: flex; justify-content: center; align-items: center; gap: 24px; flex-wrap: wrap;">
                  <div class="screenshot-item" style="border-radius: 8px; padding: 8px;">
                    <img src="/images/1a_Payment-Processing-Solutions-MainStreet-Bank.png" alt="Payment Processing Landing Page" class="screenshot-img" style="object-fit: contain; object-position: top;" />
                    <div class="screenshot-caption">
                      <h4>Merchant Services Landing Page</h4>
                      <p>Landing page designed for MainStreet Bank merchant services and payment processing solutions</p>
                    </div>
                  </div>
                  <div class="screenshot-item">
                    <img src="/images/1a_merchant_services_socaial.png" alt="Merchant Services Campaign" class="screenshot-img" />
                    <div class="screenshot-caption">
                      <h4>Merchant Services Materials</h4>
                      <p>Comprehensive marketing materials for merchant services and business banking solutions</p>
                    </div>
                  </div>
                  <div class="screenshot-item" style="max-width: 40%; min-width: 280px;">
                    <img src="/images/1a_merchant_digital_banking_ad.png" alt="Merchant Digital Banking Advertisement" class="screenshot-img" />
                    <div class="screenshot-caption">
                      <h4>Digital Banking Campaign</h4>
                      <p>Digital advertising materials targeting business banking customers with relationship-first messaging</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ) : project.slug === 'govcon-abm-campaign' ? (
          <div class="case-study-section">
            <h2 class="section-title">Project Details</h2>
            
            <div class="case-study-content">
              <div class="case-study-block">
                <h3 class="case-study-label">The Challenge</h3>
                <p class="case-study-text">
                  The bank's established relationships with government contractors had shifted due to key banker retirements. Re-establishing credibility and pipeline within the DC metro GovCon community required rebuilding trust with a notoriously specific audience that values long-term relationships over ad spend.
                </p>
              </div>

              <div class="case-study-block">
                <h3 class="case-study-label">Strategy</h3>
                <p class="case-study-text">
                  Built a pilot ABM program using three reinforcing channels: social to build awareness, in-person events to build relationships, and a content hub to demonstrate expertise. Goal: make the bank feel like the financial institution that understands GovCon businesses.
                </p>
              </div>

              <div class="case-study-block">
                <h3 class="case-study-label">Execution</h3>
                <ul class="case-study-list">
                  <li>Developed LinkedIn-targeted social campaigns reaching GovCon founders and CFOs</li>
                  <li>Planned and executed exclusive networking events positioning bank leadership as trusted advisors</li>
                  <li>Built a dedicated content hub with GovCon-specific resources: SBA guidance, contract financing explainers, banking checklists</li>
                  <li>Aligned with business banking team for warm handoffs</li>
                </ul>
              </div>

              <div class="case-study-block">
                <h3 class="case-study-label">Results</h3>
                <ul class="case-study-results">
                  <li>Launched the bank's first ABM pilot targeting the GovCon vertical</li>
                  <li>Content hub generated inbound engagement from qualified business owners</li>
                  <li>Events created direct pipeline with high-value accounts</li>
                  <li>Framework was adapted and scaled across additional verticals</li>
                </ul>
              </div>

              <div class="case-study-block">
                <h3 class="case-study-label">Project Screenshots</h3>
                <div class="project-screenshots">
                  <div class="screenshot-item" style="max-width: 70%;">
                    <img src="/images/1a_Rd-LinkedIn-03-01-2026_01_24_PM_part1.png" alt="GovCon Social Media Campaign" class="screenshot-img" style="object-position: top;" />
                    <div class="screenshot-caption">
                      <h4>Social Media Campaign</h4>
                      <p>LinkedIn and social media content targeting government contractors with relationship-first messaging</p>
                    </div>
                  </div>
                  <div class="screenshot-item" style="max-width: 70%;">
                    <img src="/images/Your-Private-GovCon-Banker-on-Speed-Dial-02-27-2026_11_55_PM.png" alt="GovCon Landing Page" class="screenshot-img" style="writing-mode: vertical-rl; text-orientation: mixed; object-position: top;" />
                    <div class="screenshot-caption">
                      <h4>Landing Page Campaign</h4>
                      <p>Targeted landing page for government contractors featuring personalized banking relationship messaging</p>
                    </div>
                  </div>
                  <div class="screenshot-item" style="max-width: 70%;">
                    <img src="/images/1_govcon_event.png" alt="GovCon Event Advertising" class="screenshot-img" style="object-fit: contain; object-position: bottom;" />
                    <div class="screenshot-caption">
                      <h4>Event Marketing</h4>
                      <p>Exclusive GovCon networking events and promotional materials for targeted business owners</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ) : null}

        <!-- Case Study Details -->
        {project.slug === 'venu-cannabis-app' ? (
          <div class="case-study-section">
            <h2 class="section-title">Project Details</h2>
            
            <div class="case-study-content">
              <div class="case-study-block">
                <h3 class="case-study-label">The Challenge</h3>
                <p class="case-study-text">
                  Most digital platforms block cannabis-related ads outright. Target dispensaries in Michigan and Illinois were skeptical of new fintech after years of unreliable payment solutions. Building trust in a restricted, skeptical market required a completely different playbook.
                </p>
              </div>

              <div class="case-study-block">
                <h3 class="case-study-label">Strategy</h3>
                <p class="case-study-text">
                  Led with education over promotion. In regulated markets where you can't say everything, content credibility is the primary trust driver. Focused on compliant content addressing real dispensary concerns: compliance, transaction reliability, and banking relationships.
                </p>
              </div>

              <div class="case-study-block">
                <h3 class="case-study-label">Execution</h3>
                <ul class="case-study-list">
                  <li>Developed compliant educational content addressing dispensary pain points without triggering platform restrictions</li>
                  <li>Built brand awareness through social on permissible platforms</li>
                  <li>Conducted targeted outreach to medical dispensaries in Michigan and Illinois</li>
                  <li>Crafted messaging around security, reliability, and regulatory compliance</li>
                </ul>
              </div>

              <div class="case-study-block">
                <h3 class="case-study-label">Results</h3>
                <ul class="case-study-results">
                  <li>Built brand awareness in target expansion markets despite channel restrictions</li>
                  <li>Compliant content drove measurable engagement from dispensary operators</li>
                  <li>Generated verified pipeline of medical dispensary prospects in Michigan & Illinois</li>
                </ul>
              </div>

              <div class="case-study-block">
