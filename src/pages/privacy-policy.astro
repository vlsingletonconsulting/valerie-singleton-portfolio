---
// src/pages/privacy-policy.astro
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Privacy Policy | Valerie Singleton"
  description="Privacy policy for portfolio.vsingleton.com"
>
  <main style="max-width:800px; margin:120px auto 80px; padding:0 24px;">
    <h1>Privacy Policy</h1>
    <p style="color:#888; margin-bottom:32px;">Last updated: January 1, 2026</p>

    <h2>Information We Collect</h2>
    <p>
      This portfolio site collects information you voluntarily submit through the contact form,
      including your name, email address, and message content.
    </p>

    <h2>How We Use Your Information</h2>
    <p>
      Contact form submissions are used solely to respond to your inquiry. Your information
      is never sold or shared with third parties for marketing purposes.
    </p>

    <h2>Contact</h2>
    <p>
      Questions? Email <a href="mailto:valerie.singleton07@gmail.com">valerie.singleton07@gmail.com</a>
    </p>

    <p style="margin-top:40px;">
      <a href="/" style="color:var(--color-accent);">← Back to Portfolio</a>
    </p>
  </main>
</Layout>
