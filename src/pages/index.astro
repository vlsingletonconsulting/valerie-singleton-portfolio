---
// src/pages/index.astro
import Layout    from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero       from '../components/Hero.astro';
import About      from '../components/About.astro';
import MyWork     from '../components/MyWork.astro';
import CaseStudy  from '../components/CaseStudy.astro';
import Contact    from '../components/Contact.astro';
---

<Layout
  title="Valerie Singleton | Senior Marketing Manager | Washington DC"
  description="Results-driven Senior Marketing Manager with 15+ years experience in B2B, financial services, and education. Expert in HubSpot/Salesforce automation, ABM strategy, technical SEO, and multi-channel campaigns."
>
  <Navigation />
  <main id="main-content">
    <Hero />
    <About />
    <MyWork />
    <CaseStudy />
    <Contact />
  </main>

  <!-- Footer -->
  <footer role="contentinfo">
    <div class="footer-inner">
      <div>
        <div class="footer-brand">Valerie<span>.</span>Singleton</div>
        <div style="font-size:0.82rem; color:rgba(255,255,255,0.4); margin-top:4px;">
          Senior Marketing Manager · Full Stack Marketer · Washington, DC
        </div>
      </div>

      <nav aria-label="Footer navigation">
        <ul class="footer-links" role="list">
          <li><a href="#hero">Home</a></li>
          <li><a href="#about">About</a></li>
          <li><a href="#case-studies">Case Studies</a></li>
          <li><a href="#contact">Contact</a></li>
          <li><a href="/privacy-policy">Privacy Policy</a></li>
          <li><a href="/terms">Terms of Use</a></li>
        </ul>
      </nav>

      <div class="footer-social" aria-label="Social media links">
        <!-- LinkedIn -->
        <a href="https://www.linkedin.com/in/valerie-singleton-8174796/" target="_blank" rel="noopener noreferrer"
           aria-label="LinkedIn profile">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
               fill="currentColor" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
        <!-- Email -->
        <a href="mailto:valerie.singleton07@gmail.com" aria-label="Send email">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
               stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </a>
      </div>

      <p class="footer-copy">
        © 2026 Valerie Singleton. All rights reserved. &nbsp;·&nbsp;
        <a href="/privacy-policy">Privacy Policy</a> &nbsp;·&nbsp;
        <a href="/terms">Terms of Use</a>
      </p>
    </div>
  </footer>
</Layout>
